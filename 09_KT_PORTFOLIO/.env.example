# MySQL / TiDB connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# Secret key for signing JWT admin tokens (use a long random string)
ADMIN_SECRET="your_long_random_secret_here"

# Google Gemini API key (if using AI features)
GEMINI_API_KEY="your_gemini_api_key_here"


